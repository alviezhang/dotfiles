#!/bin/bash
# pipx packages hash: {{ include "packages/pipx.list" | sha256sum }}
{{ if not .installPipx }}exit 0{{ end }}
set -euo pipefail

XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export PIPX_HOME="${PIPX_HOME:-$XDG_DATA_HOME/pipx}"
export PIPX_BIN_DIR="${PIPX_BIN_DIR:-$HOME/.local/bin}"
export PIPX_MAN_DIR="${PIPX_MAN_DIR:-$XDG_DATA_HOME/man}"

mkdir -p "$PIPX_BIN_DIR"

run_as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif command -v sudo &>/dev/null; then
    sudo "$@"
  else
    echo "sudo not found; rerun as root to install system packages." >&2
    return 1
  fi
}

ensure_pipx() {
  {{- if eq .chezmoi.os "darwin" }}
  local brew_bin=""
  for b in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    [ -x "$b" ] && brew_bin="$b" && break
  done
  [ -z "$brew_bin" ] && command -v brew &>/dev/null && brew_bin="$(command -v brew)"

  if [ -z "$brew_bin" ]; then
    echo "brew not found; cannot install pipx." >&2
    return 1
  fi

  "$brew_bin" install pipx || true
  {{- else if eq .chezmoi.os "linux" }}
  if command -v apt-get &>/dev/null; then
    run_as_root apt-get update -q
    run_as_root apt-get install -y pipx
  elif command -v pacman &>/dev/null; then
    run_as_root pacman -S --needed --noconfirm python-pipx
  else
    echo "No supported package manager found (apt-get/pacman); install pipx manually." >&2
    return 1
  fi
  {{- end }}
}

ensure_pipx

PIPX_BIN=""
if [ -x "$PIPX_BIN_DIR/pipx" ]; then
  PIPX_BIN="$PIPX_BIN_DIR/pipx"
elif command -v pipx &>/dev/null; then
  PIPX_BIN="$(command -v pipx)"
fi

if [ -z "$PIPX_BIN" ]; then
  echo "pipx not found after install; cannot install pipx packages." >&2
  echo "Ensure ~/.local/bin is on PATH and re-run chezmoi apply." >&2
  exit 1
fi

LIST_FILE="{{ .chezmoi.sourceDir }}/packages/pipx.list"
if [ ! -f "$LIST_FILE" ]; then
  echo "pipx package list not found: $LIST_FILE" >&2
  exit 1
fi

has_any=0
while IFS= read -r pkg || [ -n "$pkg" ]; do
  pkg="${pkg#"${pkg%%[![:space:]]*}"}"
  pkg="${pkg%"${pkg##*[![:space:]]}"}"
  case "$pkg" in
    ""|\#*|\;*) continue ;;
  esac
  has_any=1
  "$PIPX_BIN" install --force "$pkg"
done < "$LIST_FILE"

if [ "$has_any" -eq 0 ]; then
  echo "pipx package list is empty; skip."
  exit 0
fi
