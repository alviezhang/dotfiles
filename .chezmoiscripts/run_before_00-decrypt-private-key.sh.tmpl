#!/bin/bash
# key.txt.age hash: {{ include "key.txt.age" | sha256sum }}
# Re-decrypt on every apply/update so accidental local key edits are self-healed.
set -euo pipefail

KEY_FILE="${HOME}/.config/chezmoi/key.txt"
SOURCE_DIR="{{ .chezmoi.sourceDir }}"
PW_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/passphrase"

mkdir -p "${HOME}/.config/chezmoi"
command -v age >/dev/null 2>&1 || { echo "age not found in PATH" >&2; exit 1; }

# 密码来源（按优先级）：
#   1. CHEZMOI_AGE_PASSWORD env var (CI / ephemeral；same-user 进程可见，不作稳态)
#   2. macOS Keychain (iCloud-synced via dotfiles-keychain helper; falls back to security CLI)
#   3. ~/.config/dotfiles/passphrase (mode 0600)
#   4. 交互式输入（chezmoi age decrypt 自身 prompt）
#
# Fall-through 规则：
#   - 源未找到：安静下一层
#   - 源找到但为空：warning + 下一层
#   - 源访问失败（keychain 锁/拒、文件 perm 错）：warning + 下一层
#   - 拿到密码但 age 解密失败：不 fallthrough，set -e 直接报错退出

PASSWORD=""
PW_SOURCE=""        # human-readable source label, used in error messages
KEYCHAIN_BIN="${SOURCE_DIR}/scripts/dotfiles-keychain"

# 1. Env var
if [ "${CHEZMOI_AGE_PASSWORD+set}" = "set" ]; then
    if [ -n "$CHEZMOI_AGE_PASSWORD" ]; then
        PASSWORD="$CHEZMOI_AGE_PASSWORD"
        PW_SOURCE="env CHEZMOI_AGE_PASSWORD"
    else
        echo "warning: CHEZMOI_AGE_PASSWORD is set but empty; falling through" >&2
    fi
fi

# 2. macOS Keychain (iCloud-synced via pre-built Developer ID .app bundle in repo)
if [ -z "$PASSWORD" ] && [ "$(uname -s)" = "Darwin" ]; then
    KC_RC=0 KC_PW=""
    if [ -x "$KEYCHAIN_BIN" ]; then
        KC_PW=$("$KEYCHAIN_BIN" get dotfiles-passphrase "$USER" 2>/dev/null) || KC_RC=$?
    elif command -v security &>/dev/null; then
        KC_PW=$(security find-generic-password -s dotfiles-passphrase -a "$USER" -w 2>/dev/null) || KC_RC=$?
    else
        KC_RC=44
    fi
    if [ "$KC_RC" -eq 0 ] && [ -n "$KC_PW" ]; then
        PASSWORD="$KC_PW"
        PW_SOURCE="macOS Keychain (service=dotfiles-passphrase, account=$USER)"
    elif [ "$KC_RC" -eq 0 ] && [ -z "$KC_PW" ]; then
        echo "warning: Keychain entry 'dotfiles-passphrase' is empty; falling through" >&2
    elif [ "$KC_RC" -ne 44 ]; then
        echo "warning: Keychain lookup exited with $KC_RC; falling through" >&2
    fi
fi

# 3. File fallback (~/.config/dotfiles/passphrase, must be 0600)
if [ -z "$PASSWORD" ] && [ -f "$PW_FILE" ]; then
    perms=$(stat -f "%A" "$PW_FILE" 2>/dev/null || stat -c "%a" "$PW_FILE" 2>/dev/null || echo "?")
    if [ "$perms" = "600" ]; then
        FILE_PW=$(sed 's/[[:space:]]*$//' "$PW_FILE" 2>/dev/null) || FILE_PW=""
        if [ -n "$FILE_PW" ]; then
            PASSWORD="$FILE_PW"
            PW_SOURCE="file $PW_FILE"
        else
            echo "warning: ${PW_FILE} is empty or unreadable; falling through" >&2
        fi
    else
        echo "warning: ${PW_FILE} has perms ${perms}, expected 600; refusing to read" >&2
    fi
fi

# If still no password and old paths exist, emit a migration hint
if [ -z "$PASSWORD" ]; then
    if [ -f "$HOME/.config/chezmoi/password" ] || [ -f "$SOURCE_DIR/.password" ]; then
        cat >&2 <<'WARN'
warning: legacy password file detected ($HOME/.config/chezmoi/password
or $SOURCE_DIR/.password). These paths are no longer read.
Run `scripts/rotate-password` to migrate, then remove the old file.
See README "Migrating from old password paths".
WARN
    fi
fi

# 4. Decrypt
if [ -n "$PASSWORD" ] && command -v expect &>/dev/null; then
    # 非交互：通过 env var 把密码喂给 age（避免命令行参数泄漏）
    set +e
    AGE_PW="$PASSWORD" AGE_KEY="$KEY_FILE" AGE_SRC="$SOURCE_DIR/key.txt.age" \
    expect -c '
        log_user 0
        spawn age -d -o $env(AGE_KEY) $env(AGE_SRC)
        expect "Enter passphrase:"
        send "$env(AGE_PW)\r"
        expect eof
        catch wait result
        exit [lindex $result 3]
    '
    age_rc=$?
    set -e
    if [ "$age_rc" -ne 0 ]; then
        rm -f "$KEY_FILE"   # remove possibly partial / corrupt output
        cat >&2 <<EOF
Error: age failed to decrypt key.txt.age (exit $age_rc).
  Source file:     $SOURCE_DIR/key.txt.age
  Password from:   $PW_SOURCE

Most likely cause: the stored passphrase doesn't match key.txt.age.

Common scenarios:
  1. You rotated the passphrase on another machine but didn't commit/push
     key.txt.age — this machine still has the old encrypted file but the
     new passphrase (or vice versa).
       Fix on the rotating machine:
         chezmoi cd && git add key.txt.age && git commit -m "rotate passphrase" && git push
       Then on this machine:
         chezmoi update

  2. The keychain / passphrase file holds a stale value from before rotation.
       Fix:
         scripts/rotate-password   # if you have the current decrypted key.txt
       Or update the source manually (Keychain entry, or $PW_FILE).
EOF
        exit 1
    fi
else
    # 交互式
    if ! chezmoi age decrypt --output "$KEY_FILE" --passphrase "$SOURCE_DIR/key.txt.age"; then
        rm -f "$KEY_FILE"
        echo "Error: interactive age decryption failed (no password source available, or wrong passphrase entered)." >&2
        echo "  See README 'Secrets' for how to set CHEZMOI_AGE_PASSWORD / Keychain / $PW_FILE." >&2
        exit 1
    fi
fi

if [ ! -s "$KEY_FILE" ]; then
    echo "Error: $KEY_FILE is empty or missing after decryption — age reported success but produced no output." >&2
    echo "  This shouldn't normally happen; check disk space and permissions on $(dirname "$KEY_FILE")." >&2
    exit 1
fi

chmod 600 "$KEY_FILE"
