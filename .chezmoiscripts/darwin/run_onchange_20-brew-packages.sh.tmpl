#!/bin/bash
# Brewfile hash: {{ include "platform/darwin/Brewfile" | sha256sum }}
{{ if ne .chezmoi.os "darwin" }}exit 0{{ end }}
set -euo pipefail

BREW_BIN=""
for b in /opt/homebrew/bin/brew /usr/local/bin/brew; do
  [ -x "$b" ] && BREW_BIN="$b" && break
done
[ -z "$BREW_BIN" ] && command -v brew &>/dev/null && BREW_BIN="$(command -v brew)"

if [ -z "$BREW_BIN" ]; then
  echo "brew not found; skip brew bundle."
  exit 0
fi

"$BREW_BIN" bundle --no-upgrade --file="{{ .chezmoi.sourceDir }}/platform/darwin/Brewfile" \
  || echo "brew bundle: some packages failed to install"
