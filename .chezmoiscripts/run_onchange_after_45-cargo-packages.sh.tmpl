#!/bin/bash
# cargo packages hash: {{ include "packages/cargo.list" | sha256sum }}
set -euo pipefail

XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export CARGO_HOME="${CARGO_HOME:-$XDG_DATA_HOME/cargo}"
LEGACY_CARGO_HOME="${HOME}/.cargo"
export RUSTUP_HOME="${RUSTUP_HOME:-$XDG_DATA_HOME/rustup}"
LEGACY_RUSTUP_HOME="${HOME}/.rustup"

CARGO_BIN=""
RUSTUP_BIN=""

if [ -d "$RUSTUP_HOME" ] && [ -x "$CARGO_HOME/bin/rustup" ] && [ -x "$CARGO_HOME/bin/cargo" ]; then
  RUSTUP_BIN="$CARGO_HOME/bin/rustup"
  CARGO_BIN="$CARGO_HOME/bin/cargo"
elif [ -d "$LEGACY_RUSTUP_HOME" ] && [ -x "$LEGACY_CARGO_HOME/bin/rustup" ] && [ -x "$LEGACY_CARGO_HOME/bin/cargo" ]; then
  RUSTUP_BIN="$LEGACY_CARGO_HOME/bin/rustup"
  CARGO_BIN="$LEGACY_CARGO_HOME/bin/cargo"
fi

if [ -z "$RUSTUP_BIN" ] || ! "$RUSTUP_BIN" show active-toolchain &>/dev/null; then
  echo "rustup-managed cargo not found; skip cargo packages."
  exit 0
fi

LIST_FILE="{{ .chezmoi.sourceDir }}/packages/cargo.list"
if [ ! -f "$LIST_FILE" ]; then
  echo "cargo package list not found: $LIST_FILE" >&2
  exit 1
fi

has_any=0
while IFS= read -r crate || [ -n "$crate" ]; do
  crate="${crate#"${crate%%[![:space:]]*}"}"
  crate="${crate%"${crate##*[![:space:]]}"}"
  case "$crate" in
    ""|\#*|\;*) continue ;;
  esac
  has_any=1
  if ! "$CARGO_BIN" install --locked "$crate"; then
    echo "cargo install --locked failed for '$crate'; retry without --locked..." >&2
    "$CARGO_BIN" install "$crate"
  fi
done < "$LIST_FILE"

if [ "$has_any" -eq 0 ]; then
  echo "cargo package list is empty; skip."
  exit 0
fi
