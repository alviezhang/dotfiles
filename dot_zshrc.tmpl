export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="bira"

# Locale
export LANG=en_US.UTF-8
export LANGUAGE=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# XDG Base Directory Specification
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# pipx (XDG)
export PIPX_HOME="${PIPX_HOME:-$XDG_DATA_HOME/pipx}"
export PIPX_BIN_DIR="${PIPX_BIN_DIR:-$HOME/.local/bin}"
export PIPX_MAN_DIR="${PIPX_MAN_DIR:-$XDG_DATA_HOME/man}"

# Rust / Cargo (XDG)
export CARGO_HOME="${CARGO_HOME:-$XDG_DATA_HOME/cargo}"
export RUSTUP_HOME="${RUSTUP_HOME:-$XDG_DATA_HOME/rustup}"
export PATH="$CARGO_HOME/bin:$PATH"

plugins=(git golang
{{- if eq .chezmoi.os "darwin" }} macos brew{{ end }}
{{- if eq .chezmoi.os "linux" }}
  {{- if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "endeavouros") }} archlinux{{ end }}
  {{- if eq .chezmoi.osRelease.id "ubuntu" }} ubuntu{{ end }}
  {{- if eq .chezmoi.osRelease.id "debian" }} debian{{ end }}
{{- end }})

if [[ -s "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# --- Custom helpers (moved from ~/.oh-my-zsh/custom/*.zsh) ---

# 代理配置
proxy() {
  export PROXYHOST="${PROXYHOST:-10.0.10.20}"
  export http_proxy="http://${PROXYHOST}:${PROXYHTTPPORT:-7890}"
  export https_proxy="http://${PROXYHOST}:${PROXYHTTPPORT:-7890}"
  export all_proxy="socks5://${PROXYHOST}:${PROXYSOCKSPORT:-7891}"
  echo "Proxy ON: http=$http_proxy socks=$all_proxy"
}

direct() {
  unset http_proxy https_proxy all_proxy
  echo "Proxy OFF"
}

if [[ -f "$HOME/.config/proxy.sh" ]]; then
  . "$HOME/.config/proxy.sh"
  proxy
fi

# Linux: 只在 open 未定义且 xdg-open 存在时创建 alias
{{- if eq .chezmoi.os "linux" }}
if ! type open &>/dev/null && command -v xdg-open &>/dev/null; then
  alias open='xdg-open'
fi
{{- end }}

# --- PATH 集中配置（按工具存在性加载） ---

{{ if eq .chezmoi.os "darwin" -}}
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

# Go
if command -v go &>/dev/null; then
  export GOPATH="$HOME/go"
  mkdir -p "$GOPATH"
  export PATH="$GOPATH/bin:$PATH"
fi

# Rust mirrors (only when rustup is installed)
if [[ -d "$RUSTUP_HOME" ]]; then
  export RUSTUP_DIST_SERVER=https://mirrors.ustc.edu.cn/rust-static
  export RUSTUP_UPDATE_ROOT=https://mirrors.ustc.edu.cn/rust-static/rustup
fi

# fnm (Node.js)
export FNM_DIR="${FNM_DIR:-$XDG_DATA_HOME/fnm}"
fnm_exec=""
if [[ -x "$FNM_DIR/fnm" ]]; then
  fnm_exec="$FNM_DIR/fnm"
elif command -v fnm &>/dev/null; then
  fnm_exec="$(command -v fnm)"
fi
if [[ -n "$fnm_exec" ]] && [[ "${_DOTFILES_FNM_ENV_DONE-}" != "$$" ]]; then
  # Avoid PATH growth in nested shells / repeated sourcing.
  path=("${path[@]:#${XDG_STATE_HOME}/fnm_multishells/*/bin}")
  path=("${path[@]:#$FNM_DIR}")

  eval "$("$fnm_exec" env --use-on-cd)"
  _DOTFILES_FNM_ENV_DONE="$$"
fi
unset fnm_exec

# Ensure ~/.local/bin is on PATH (avoid duplicates if already added elsewhere).
if (( ${path[(ie)$HOME/.local/bin]} > $#path )); then
  path=("$HOME/.local/bin" "${path[@]}")
fi

# Add /usr/local/sbin only when it exists on this machine; otherwise remove it.
if [[ -d /usr/local/sbin ]]; then
  if (( ${path[(ie)/usr/local/sbin]} > $#path )); then
    user_bin="$HOME/.local/bin"
    user_bin_idx=${path[(ie)$user_bin]}
    if (( user_bin_idx <= $#path )); then
      path=("${path[1,user_bin_idx]}" /usr/local/sbin "${path[user_bin_idx+1,-1]}")
    else
      path=(/usr/local/sbin "${path[@]}")
    fi
    unset user_bin user_bin_idx
  fi
else
  if (( ${path[(ie)/usr/local/sbin]} <= $#path )); then
    path=("${path[@]:#/usr/local/sbin}")
  fi
fi
