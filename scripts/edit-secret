#!/bin/bash
set -e

command -v age >/dev/null 2>&1 || { echo "age not found. Install with: brew install age"; exit 1; }

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
AGE_KEY="$HOME/.config/chezmoi/key.txt"
AGE_RECIPIENT_FILE="$REPO_DIR/age-recipient.txt"
if [ ! -f "$AGE_RECIPIENT_FILE" ]; then
  echo "Age recipient file not found: $AGE_RECIPIENT_FILE" >&2
  exit 1
fi
AGE_RECIPIENT="$(tr -d ' \t\r\n' < "$AGE_RECIPIENT_FILE")"

if [ -z "$1" ]; then
  echo "Usage: $0 <encrypted-file>"
  echo "Example: $0 git-identity.toml.age"
  exit 1
fi

FILE="$REPO_DIR/$1"
if [ ! -f "$FILE" ]; then
  echo "File not found: $FILE"
  exit 1
fi

TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

age -d -i "$AGE_KEY" "$FILE" > "$TMPFILE"
BEFORE=$(shasum "$TMPFILE")

${EDITOR:-vim} "$TMPFILE"

if [ "$(shasum "$TMPFILE")" != "$BEFORE" ]; then
  age -r "$AGE_RECIPIENT" -o "$FILE" "$TMPFILE"
  echo "Encrypted and saved: $1"
else
  echo "No changes."
fi
